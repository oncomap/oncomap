web/dist/
web/public/site.json

# Generated artifacts (records + schema are the source of truth; build/ scripts
# are tracked - only their compiled output is ignored)
build/dist/
build/_generated/
site/dist/
site/_build/
_site/
site/site.json

# Data working files
*.parquet
*.log
.env
.env.*
!.env.example
extract/proposals/

# graphify knowledge-graph output (local analysis artifact, not project source)
graphify-out/

# Structured run logs - a run artifact, uploaded by CI, not source
logs/

# Paper + figures + their generation code are NOT part of the public repo.
# The paper lives on bioRxiv/Zenodo; figures and the notebooks/scripts that
# generate them are scratch. Directory ignores plus belt-and-suspenders globs
# so a stray artifact anywhere in the tree can never be committed.
paper/
oncomap-figures/
_to_delete/
**/figures/
*.ipynb
figure*.py
figure*.png
figure*.svg
figure*.pdf
make_paper_figures.py
*.pdf
*.docx
*.pptx

# Internal session handoff notes / scratch docs
handoff.md

# graph-layer/ - WIP API component, deferred until it's ready for public release
graph-layer/

# Brand source images (only the derived favicons in web/public/ are tracked)
logo/
