# OncoMap secrets template.
# Copy to .env (gitignored) and fill in. NEVER commit real keys.
# Only `access: open` data is ever cataloged with resolvable links; these keys
# are for querying source registries during extraction/verification, not for
# mirroring controlled-access data.

# NCBI E-utilities (GEO/SRA lookups). <=10 req/s with a key.
NCBI_API_KEY=

# Synapse (HTAN metadata). Personal access token.
SYNAPSE_AUTH_TOKEN=

# Zenodo (DOI provenance / release deposit).
ZENODO_TOKEN=
